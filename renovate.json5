// Renovate Bot Configuration for augint-shell
// Docs: https://docs.renovatebot.com/configuration-options/
{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  // Extend recommended defaults + pin GH Actions to SHA digests
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver"
  ],

  "rebaseWhen": "behind-base-branch",

  // Weekly Sunday night, so PRs merge before Monday 7am API deploy
  "schedule": ["before 11:59pm on Sunday"],
  "timezone": "America/Los_Angeles",

  // Use GitHub's native auto-merge (respects branch protection)
  "platformAutomerge": true,
  // "auto" defers to repo merge method settings
  "automergeStrategy": "auto",

  // Let Renovate decide based on range specifiers (>= only touches lockfile for in-range)
  "rangeStrategy": "auto",

  // Only manage what we want -- disable Docker managers
  "enabledManagers": [
    "pep621",
    "pre-commit",
    "github-actions"
  ],

  // Labels for all Renovate PRs
  "labels": ["dependencies", "renovate"],

  // Lockfile maintenance: monthly uv lock refresh for transitive deps
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 11:59pm on the first day of the month"],
    "commitMessageAction": "refresh",
    "automerge": true
  },

  // Vulnerability alerts bypass schedule -- fix ASAP
  "vulnerabilityAlerts": {
    "enabled": true,
    "schedule": ["at any time"],
    "labels": ["dependencies", "security"],
    "commitMessagePrefix": "fix(deps):",
    "automerge": true
  },

  "packageRules": [
    // ---------------------------------------------------------------
    // Production dependencies
    // ---------------------------------------------------------------

    // Prod patches: automerge with chore prefix (no release)
    {
      "matchDepTypes": ["project.dependencies"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["patch"],
      "commitMessagePrefix": "chore(deps):",
      "automerge": true
    },

    // Prod minors: manual review, no release
    {
      "matchDepTypes": ["project.dependencies"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["minor"],
      "commitMessagePrefix": "chore(deps):",
      "automerge": false
    },

    // Prod majors: require dashboard approval, no release
    {
      "matchDepTypes": ["project.dependencies"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["major"],
      "commitMessagePrefix": "chore(deps):",
      "automerge": false,
      "dependencyDashboardApproval": true
    },

    // ---------------------------------------------------------------
    // Dev dependencies (grouped)
    // ---------------------------------------------------------------

    // Dev patches + minors: automerge, grouped
    {
      "matchDepTypes": ["project.optional-dependencies", "dependency-groups"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["patch", "minor"],
      "commitMessagePrefix": "chore(deps-dev):",
      "automerge": true,
      "groupName": "dev dependency updates",
      "groupSlug": "dev-deps"
    },

    // Dev majors: manual review
    {
      "matchDepTypes": ["project.optional-dependencies", "dependency-groups"],
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["major"],
      "commitMessagePrefix": "chore(deps-dev):",
      "automerge": false
    },

    // ---------------------------------------------------------------
    // python-semantic-release: never automerge
    // ---------------------------------------------------------------
    {
      "matchPackageNames": ["python-semantic-release"],
      "automerge": false,
      "commitMessagePrefix": "chore(deps-dev):"
    },

    // ---------------------------------------------------------------
    // GitHub Actions (automerge all; gates + staging catch regressions)
    // ---------------------------------------------------------------
    {
      "matchManagers": ["github-actions"],
      "commitMessagePrefix": "ci(deps):",
      "automerge": true,
      "groupName": "GitHub Actions",
      "groupSlug": "gh-actions"
    },

    // ---------------------------------------------------------------
    // Pre-commit hooks (automerge)
    // ---------------------------------------------------------------
    {
      "matchManagers": ["pre-commit"],
      "commitMessagePrefix": "ci(deps):",
      "automerge": true
    }
  ]
}

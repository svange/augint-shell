      },
      "models": {
        "anthropic.claude-sonnet-4-20250514-v1:0": {
          "name": "Claude Sonnet 4 (Bedrock)"
        },
        "anthropic.claude-opus-4-20250514-v1:0": {
          "name": "Claude Opus 4 (Bedrock)"
        },
        "anthropic.claude-haiku-4-5-20251001-v1:0": {

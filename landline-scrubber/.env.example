# Workspace root .env -- managed via chezmoi
# No dynamic values here. Cross-stack communication uses CFN outputs / APIs.
# Submodule-specific secrets live in each submodule's own .env.

# GitHub
GH_TOKEN=
GH_ACCOUNT=
GH_REPO=

# AWS CLI profile (optional, for local dev only)
AWS_PROFILE=
AWS_REGION=us-east-1
